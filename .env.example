# ---- Copy to .env and adjust. The stack runs as-is with these defaults. ----

# --- Database ---
# Default: zero-infra SQLite file (no server needed). The backend creates it.
DATABASE_URL=sqlite+aiosqlite:///./helix.db
# For Postgres (Docker/prod), use instead:
#   DATABASE_URL=postgresql+asyncpg://helix:helix@postgres:5432/helix
POSTGRES_USER=helix
POSTGRES_PASSWORD=helix
POSTGRES_DB=helix
# Create tables at boot. Leave true when self-hosting: it is what keeps the
# install a single command. Set to false if you run migrations yourself
# (`alembic upgrade head` from backend/) — both build the same schema, and the
# test suite asserts they agree.
DB_AUTO_CREATE=true
#
# Hosted Postgres (Supabase, Neon, RDS, ...) is just Postgres — point
# DATABASE_URL at it and keep the "+asyncpg" driver:
#   DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
# Supabase also offers a transaction-mode pooler on port 6543. If you use that
# port, set DB_POOLED=true: the pooler cannot support asyncpg's prepared
# statements, and without this you get intermittent
# 'prepared statement "__asyncpg_stmt_N__" does not exist' errors that appear
# only under concurrency. Run migrations against 5432 either way.
DB_POOLED=false

# --- Auth (M1) ---
JWT_SECRET=dev-only-change-me
FRONTEND_BASE_URL=http://localhost:5173

# --- LLM provider ---
# One of: stub | groq | ollama
# stub   -> echoes the prompt back token-by-token (zero setup, default)
# groq   -> hosted inference, needs GROQ_API_KEY
# ollama -> local inference, needs the ollama service running
LLM_PROVIDER=stub

# Groq (only used when LLM_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (only used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000

# --- Deep Reasoning (Ouroboros) ---
# Runs on Groq regardless of LLM_PROVIDER (needs GROQ_API_KEY). Chat and deep
# reasoning use separate models on purpose: chat can stay fast/cheap while the
# recursive reasoning loop uses the strongest model.
DEEP_REASONING_MODEL=llama-3.3-70b-versatile
# Tool policy (FR-14): may deep runs take the web-research detour? Research
# additionally requires TAVILY_API_KEY to do anything at all.
DEEP_REASONING_ALLOW_RESEARCH=true
# TAVILY_API_KEY=
# Convergence thresholds auto-calibrate to the active embedder (neural MiniLM
# when sentence-transformers is installed, else a lexical fallback). Pin only
# if you know what you're doing:
# DEEP_REASONING_STABILITY_THRESHOLD=0.90

# --- Abuse limits -----------------------------------------------------------
# The threat is database spam, not token theft: keys are per-workspace, so a
# flood burns the workspace's own provider quota. Defaults are sized to be
# invisible to real use. Every one of these disables itself when set to 0.
#
# Rate limits — sliding window per user, or per IP when unauthenticated.
RATE_LIMIT_ENABLED=true
# Registration and login share this budget, so spending the signup allowance
# does not leave password guessing free.
RATE_LIMIT_AUTH_PER_HOUR=20
RATE_LIMIT_MESSAGES_PER_MINUTE=30
# Deep and agent runs each fan out into many model and tool calls.
RATE_LIMIT_RUNS_PER_MINUTE=10
# Uploads are the heaviest write: a file, plus a chunk row per ~220 words and
# an embedding per chunk.
RATE_LIMIT_UPLOADS_PER_HOUR=120
#
# Standing caps (as opposed to rates).
MAX_WORKSPACES_PER_USER=20
MAX_MEMBERS_PER_WORKSPACE=50
# How many times one invite link may be redeemed. Expiry alone left a leaked
# link open to everyone who saw it.
INVITE_MAX_USES=25
# Request body caps, enforced as middleware before any handler runs.
MAX_REQUEST_BYTES=12582912
MAX_MESSAGE_BYTES=65536
# Uploads: file size, and the extracted text kept per document.
DOCUMENT_MAX_BYTES=8388608
DOCUMENT_MAX_CHARS=500000

# --- Hosted instance (all optional; every one is off by default) -------------
# A populated example workspace for every new account: a forked thread, a
# reference edge, a finished deep-run trace, an ingested document. Static text,
# so it costs no tokens and works before a provider key is pasted.
SEED_EXAMPLE_WORKSPACE=true
#
# Banner shown on every page, including the login screen. Empty = no banner,
# which is right for self-hosting: it's your instance and your data.
PUBLIC_NOTICE=
# PUBLIC_NOTICE=This is a free demo instance — data may be wiped with notice.
PUBLIC_NOTICE_LINK=https://github.com/Achindra2003/Helix
#
# Password reset email. Unset = no email sent and the reset link is written to
# the server log, which is what you want locally. Requires a Resend account and
# a verified sending domain. (Email *verification* is deliberately not
# implemented — BYO keys mean a fake account cannot spend anything.)
RESEND_API_KEY=
EMAIL_FROM=Helix <onboarding@resend.dev>
PASSWORD_RESET_TTL_MINUTES=30
#
# Crash reporting. Unset = no SDK, no network client, nothing reported.
# Needs `pip install sentry-sdk`, which is not in requirements.txt on purpose.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# Errors are always reported; performance traces default to off so they don't
# consume a free tier's quota.
SENTRY_TRACES_SAMPLE_RATE=0.0

# --- LLM observability (optional; api/telemetry.py) -------------------------
# Point at any OTLP/HTTP backend to get GenAI spans for every LLM call.
# Self-hosted Langfuse example:
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:3000/api/public/otel
#   OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64 of pk-lf-...:sk-lf-...>
# Unset = no-op tracer, nothing exported (the default; tests rely on this).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=helix-api
